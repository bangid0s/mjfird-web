# Canonical site URL (no trailing slash) — used for sitemap, RSS, social metadata
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the client. Used only in trusted server routes.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (inquiry email notifications)
RESEND_API_KEY=
INQUIRY_NOTIFY_EMAIL=hello@mjfird.com

# Cloudflare Turnstile (spam protection on the inquiry form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
